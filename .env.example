# LOCAL DEVELOPMENT ONLY. Servers and deployment targets never carry env
# files: runtime env is injected through Doppler at deploy time (see
# docs/doppler-runtime-env.md).
HTTP_ADDR=:8080
DATABASE_URL=postgres://deploy:deploy@localhost:5432/deploy_manager?sslmode=disable
REDIS_URL=redis://localhost:6379/0
STATIC_DIR=web/dist
SSH_KNOWN_HOSTS_PATH=./known_hosts

# How Deploy Manager obtains an SSH signer for connecting to target servers.
#   file = read a static private key from each server's ssh_key_path (default)
#   ca   = mint short-lived CA-signed certificates (not yet wired; needs a CA)
SSH_SIGNER_MODE=file

# Static bearer token required on all /api endpoints except health checks and
# the GitHub webhook. For local development only, set AUTH_DISABLED=true instead.
# Must be at least 16 characters when set.
API_TOKEN=
AUTH_DISABLED=false

GITHUB_WEBHOOK_SECRET=
GITHUB_APP_ID=
GITHUB_APP_SLUG=
# Prefer the path form in production so the private key does not live in a
# shell env var. Provide exactly one of these two.
GITHUB_APP_PRIVATE_KEY_PATH=
GITHUB_APP_PRIVATE_KEY=

DOPPLER_PROJECT=
DOPPLER_CONFIG=
DOPPLER_TOKEN=
DOPPLER_CLI_PATH=doppler

SLACK_WEBHOOK_URL=

RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TO_EMAIL=
